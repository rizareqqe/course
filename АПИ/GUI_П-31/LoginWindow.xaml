<Window x:Class="GuiP31.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="360"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Фильмотека организации"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,20"
                   Text="Авторизация по данным базы MySQL. Для старта доступны учетные записи admin/admin123 и editor/editor123."
                   TextWrapping="Wrap"
                   Foreground="#44515A" />

        <TextBlock Grid.Row="2" Text="Логин" Margin="0,0,0,4"/>
        <TextBox x:Name="LoginTextBox" Grid.Row="3" />

        <TextBlock Grid.Row="4" Text="Пароль" Margin="0,8,0,4"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="5" Height="34" Padding="8,6" VerticalAlignment="Top" />

        <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
            <Border Background="#FDECEC" CornerRadius="8" Padding="12" Visibility="Collapsed" x:Name="ErrorPanel">
                <TextBlock x:Name="ErrorTextBlock" Foreground="#B42318" TextWrapping="Wrap" />
            </Border>
            <Button Margin="0,16,0,0" Height="40" Content="Войти" Click="Login_Click"/>
        </StackPanel>
    </Grid>
</Window>
