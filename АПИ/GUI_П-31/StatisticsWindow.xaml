<Window x:Class="GuiP31.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика по фильмам"
        Height="560"
        Width="820"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Сводная ведомость и график"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock x:Name="SummaryTextBlock" Margin="0,12,0,20" />

            <TextBlock Text="По режиссерам" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <ItemsControl x:Name="DirectorsChartItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#DDECEA" Height="24" CornerRadius="6">
                                <Rectangle Fill="{StaticResource AccentBrush}" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding Count}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="По жанрам" FontSize="18" FontWeight="Bold" Margin="0,20,0,8"/>
            <DataGrid x:Name="GenresGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Жанр" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Количество фильмов" Binding="{Binding Count}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</Window>
