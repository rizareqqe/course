<Window x:Class="GuiP31.ActorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Актеры"
        Height="520"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">
    <DockPanel Margin="16">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"/>
            </StatusBarItem>
        </StatusBar>

        <StackPanel>
            <TextBlock Text="Справочник актеров" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,12">
                <TextBox x:Name="SearchTextBox" Width="340"/>
                <Button Content="Поиск" Click="Search_Click"/>
                <Button Content="Сбросить" Click="Reset_Click"/>
                <Button Content="Добавить" Click="Add_Click"/>
                <Button Content="Изменить" Click="Edit_Click"/>
                <Button Content="Удалить" Click="Delete_Click"/>
            </StackPanel>

            <DataGrid x:Name="ActorGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя актера" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DockPanel>
</Window>
