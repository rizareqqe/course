<Window x:Class="GuiP31.MovieEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка фильма"
        Height="720"
        Width="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#FDECEC" Padding="12" Visibility="Collapsed" x:Name="ErrorPanel">
            <TextBlock x:Name="ErrorTextBlock" Foreground="#B42318" TextWrapping="Wrap"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Карточка фильма" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />

                <TextBlock Grid.Row="1" Text="Название" Margin="0,16,0,4"/>
                <TextBox x:Name="TitleTextBox" Grid.Row="2" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="3" Text="Год выпуска" Margin="0,8,0,4"/>
                <TextBox x:Name="YearTextBox" Grid.Row="4" Width="180" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Text="Режиссер" Margin="12,8,0,4"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <ComboBox x:Name="DirectorComboBox" Width="230" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    <Button Content="Справочник" Click="ManageDirectors_Click"/>
                </StackPanel>

                <TextBlock Grid.Row="5" Text="Описание" Margin="0,8,0,4"/>
                <TextBox x:Name="DescriptionTextBox" Grid.Row="6" Grid.ColumnSpan="2" Height="90" AcceptsReturn="True" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="7" Text="Жанры" Margin="0,8,0,4" VerticalAlignment="Top"/>
                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="12,8,0,0" VerticalAlignment="Top">
                    <Button Content="Справочник жанров" Click="ManageGenres_Click"/>
                    <Button Content="Справочник актеров" Click="ManageActors_Click"/>
                </StackPanel>

                <Grid Grid.Row="8" Grid.ColumnSpan="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Выберите жанры" />
                    <TextBlock Grid.Column="1" Text="Выберите актеров" />

                    <ListBox x:Name="GenresListBox"
                             Grid.Row="1"
                             Margin="0,4,8,0"
                             SelectionMode="Extended"
                             DisplayMemberPath="Name"
                             MinHeight="200"/>
                    <ListBox x:Name="ActorsListBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="8,4,0,0"
                             SelectionMode="Extended"
                             DisplayMemberPath="Name"
                             MinHeight="200"/>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                        <StackPanel x:Name="CuratorPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Куратор" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CuratorComboBox" Width="220" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>
                        <Button Content="Сохранить" Click="Save_Click"/>
                        <Button Content="Отмена" Click="Cancel_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
